---
/**
 * Feature: small, opinionated card for the landing page.
 *
 * Differs from Starlight's <LinkCard /> by rendering an icon glyph
 * (a stencil-y SVG) above the title rather than a chevron, and by
 * snapping titles to the accent colour on hover. Used in the "What
 * you get" section on /index.mdx.
 *
 * Pass icon as a name from the Feature.iconMap below. Ship a new key
 * here when you want a new glyph; we keep them inline so the page
 * stays zero-JS.
 */

import { withBase } from "../utils/base.mjs";

const { title, href, icon = "tile" } = Astro.props as {
  title: string;
  href: string;
  icon?: keyof typeof iconMap;
};

const finalHref = href.startsWith("/") ? withBase(href) : href;

const iconMap = {
  tile: `<rect x="3" y="3" width="8" height="8" rx="2"/><rect x="13" y="3" width="8" height="8" rx="2"/><rect x="3" y="13" width="8" height="8" rx="2"/><rect x="13" y="13" width="8" height="8" rx="2"/>`,
  wire: `<path d="M3 6h18M3 12h12M3 18h18"/><circle cx="20" cy="12" r="2"/>`,
  bolt: `<path d="M13 2 L4 14 h7 l-1 8 9-12 h-7 z"/>`,
  shield: `<path d="M12 2 L4 5 v6 c0 5 3.5 9 8 11 4.5-2 8-6 8-11 V5 z"/>`,
  layers: `<path d="M12 3 2 8 l10 5 10-5 z"/><path d="M2 13 l10 5 10-5"/><path d="M2 18 l10 5 10-5"/>`,
  cycle: `<path d="M21 12 a9 9 0 1 1-3-6.7"/><path d="M21 4 v5 h-5"/>`,
  cli:   `<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 9 l3 3 -3 3"/><path d="M12 15 h6"/>`,
  sparkle: `<path d="M12 3 l1.8 5 5 1.8 -5 1.8 -1.8 5 -1.8-5 -5-1.8 5-1.8 z"/>`,
};
---
<a class="wun-feature" href={finalHref} data-icon={icon}>
  <span class="wun-feature__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
      <Fragment set:html={iconMap[icon]} />
    </svg>
  </span>
  <span class="wun-feature__title">{title}</span>
  <span class="wun-feature__body"><slot /></span>
  <span class="wun-feature__cta" aria-hidden="true">Read →</span>
</a>
