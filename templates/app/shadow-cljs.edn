;; Web build config. Reads classpath from deps.edn (`:deps true`).
;; The init-fn hooks into wun.web.core/init via myapp.web.main.

{:source-paths ["src"]
 :deps         true
 :dev-http     {8081 "public"}

 :builds
 {:app {:target     :browser
        :output-dir "public/js"
        :asset-path "/js"
        :modules    {:main {:init-fn myapp.web.main/init}}
        :devtools   {:after-load myapp.web.main/after-reload}}}}
