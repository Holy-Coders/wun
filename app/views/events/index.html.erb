<h1>Events: <%= @card.title %></h1>
<p><%= link_to "Back to card", card_path(current_account.slug, @card) %></p>

<table>
  <thead>
    <tr>
      <th>Time</th>
      <th>Action</th>
      <th>Actor</th>
      <th>Details</th>
    </tr>
  </thead>
  <tbody>
    <% @events.each do |event| %>
      <tr>
        <td><%= event.created_at.strftime("%Y-%m-%d %H:%M:%S") %></td>
        <td><code><%= event.action %></code></td>
        <td><%= event.actor.name %></td>
        <td>
          <% if event.metadata.present? %>
            <code><%= event.metadata.to_json %></code>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
