<%= link_to "Back", account_root_path(current_account.slug), class: "back-link" %>

<h1>Rules</h1>

<% if @system_rules.any? %>
  <h2>System Rules</h2>
  <% @system_rules.each do |rule| %>
    <div class="rule-item <%= 'rule-disabled' unless rule.active? %>">
      <div class="rule-header">
        <strong><%= rule.name %></strong>
        <span class="tag">system</span>
        <% unless rule.active? %><span class="tag">disabled</span><% end %>
      </div>
      <div class="rule-detail">
        On <code><%= rule.trigger %></code>
        <% if rule.action_config&.dig("when_tag") %>
          when tag = <code><%= rule.action_config["when_tag"] %></code>
        <% end %>
        <% if rule.action_config&.dig("keyword") %>
          when comment contains "<code><%= rule.action_config["keyword"] %></code>"
        <% end %>
        &rarr; <code><%= rule.action_type %></code> <code><%= rule.action_config&.dig("tag") %></code>
      </div>
    </div>
  <% end %>
<% end %>

<h2>Your Rules</h2>

<% if @user_rules.any? %>
  <% @user_rules.each do |rule| %>
    <div class="rule-item <%= 'rule-disabled' unless rule.active? %>">
      <div class="rule-header">
        <strong><%= rule.name %></strong>
        <% unless rule.active? %><span class="tag">disabled</span><% end %>
        <div class="rule-actions">
          <%= link_to "Edit", edit_rule_path(current_account.slug, rule), class: "btn" %>
          <%= button_to "Delete", rule_path(current_account.slug, rule), method: :delete, class: "btn btn-danger" %>
        </div>
      </div>
      <div class="rule-detail">
        On <code><%= rule.trigger %></code>
        <% if rule.action_config&.dig("when_tag") %>
          when tag = <code><%= rule.action_config["when_tag"] %></code>
        <% end %>
        <% if rule.action_config&.dig("keyword") %>
          when comment contains "<code><%= rule.action_config["keyword"] %></code>"
        <% end %>
        &rarr; <code><%= rule.action_type %></code> <code><%= rule.action_config&.dig("tag") %></code>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="empty">No custom rules yet.</div>
<% end %>

<div class="section-gap">
  <%= link_to "New rule", new_rule_path(current_account.slug), class: "btn btn-primary" %>
</div>
