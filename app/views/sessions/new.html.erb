<h1>Sign in</h1>

<%= form_with url: session_path, method: :post do |f| %>
  <div class="form-group">
    <%= f.label :account_slug, "Account" %>
    <%= f.text_field :account_slug, required: true, autofocus: true %>
  </div>

  <div class="form-group">
    <%= f.label :email_address, "Email" %>
    <%= f.email_field :email_address, required: true %>
  </div>

  <div class="form-group">
    <%= f.label :password %>
    <%= f.password_field :password, required: true %>
  </div>

  <%= f.submit "Sign in", class: "btn btn-primary" %>
<% end %>
