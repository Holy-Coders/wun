<h1>Segment Audit</h1>

<% total_issues = @audit.values.sum(&:size) %>
<% if total_issues == 0 %>
  <div class="notice">All clear — no segment issues found.</div>
<% else %>
  <div class="alert">Found <%= total_issues %> issue<%= total_issues == 1 ? "" : "s" %>.</div>
  <%= button_to "Auto-repair", repair_dashboard_path(current_account.slug), class: "btn btn-danger section-gap" %>
<% end %>

<h2>Overlapping Segments (<%= @audit[:overlapping].size %>)</h2>
<% if @audit[:overlapping].any? %>
  <table>
    <thead><tr><th>User</th><th>Segment A</th><th>Segment B</th><th>Overlap</th></tr></thead>
    <tbody>
      <% @audit[:overlapping].each do |issue| %>
        <tr>
          <td><%= User.find(issue[:user_id]).name %></td>
          <td>#<%= issue[:segment_a] %></td>
          <td>#<%= issue[:segment_b] %></td>
          <td><%= issue[:overlap_seconds] %>s</td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="empty">None</div>
<% end %>

<h2>Boundary Violations (<%= @audit[:boundary_violations].size %>)</h2>
<% if @audit[:boundary_violations].any? %>
  <table>
    <thead><tr><th>Segment</th><th>User</th><th>Boundary</th><th>Stopped at</th></tr></thead>
    <tbody>
      <% @audit[:boundary_violations].each do |issue| %>
        <tr>
          <td>#<%= issue[:segment_id] %></td>
          <td><%= User.find(issue[:user_id]).name %></td>
          <td><%= issue[:boundary] %></td>
          <td><%= issue[:stopped_at] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="empty">None</div>
<% end %>

<h2>Long Segments > 8h (<%= @audit[:long_segments].size %>)</h2>
<% if @audit[:long_segments].any? %>
  <table>
    <thead><tr><th>Segment</th><th>User</th><th>Card</th><th>Hours</th></tr></thead>
    <tbody>
      <% @audit[:long_segments].each do |issue| %>
        <tr>
          <td>#<%= issue[:segment_id] %></td>
          <td><%= User.find(issue[:user_id]).name %></td>
          <td><%= Card.find(issue[:card_id]).title %></td>
          <td><%= issue[:hours] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="empty">None</div>
<% end %>

<h2>Orphaned Open Segments (<%= @audit[:orphaned_open].size %>)</h2>
<% if @audit[:orphaned_open].any? %>
  <table>
    <thead><tr><th>Segment</th><th>User</th><th>Card</th></tr></thead>
    <tbody>
      <% @audit[:orphaned_open].each do |issue| %>
        <tr>
          <td>#<%= issue[:segment_id] %></td>
          <td><%= User.find(issue[:user_id]).name %></td>
          <td><%= Card.find(issue[:card_id]).title %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="empty">None</div>
<% end %>

<div class="section-gap">
  <%= link_to "Back to Dashboard", dashboard_path(current_account.slug), class: "btn" %>
</div>
