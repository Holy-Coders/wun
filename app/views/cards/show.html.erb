<p><%= link_to "Back", account_root_path(current_account.slug) %></p>

<div class="card-detail">
  <div class="card-title"><%= @card.title %></div>

  <% if @card.active? %>
    <span class="tag">Active</span>
  <% elsif @card.done? %>
    <span class="tag">Done</span>
  <% end %>
  <% if @card.blocked? %>
    <span class="tag">Blocked</span>
  <% end %>

  <% if @card.body.present? %>
    <div class="card-body"><%= @card.body %></div>
  <% end %>

  <div class="tags">
    <% @card.taggings.includes(:tag).select { |t| !t.tag.system? }.each do |tagging| %>
      <span class="tag">
        <%= render_structured_tag(tagging.tag.name, current_account) %>
        <%= button_to "x", card_tagging_path(current_account.slug, @card, tagging), method: :delete, class: "tag-remove" %>
      </span>
    <% end %>
  </div>

  <div class="actions">
    <% if @card.active? %>
      <%= button_to "Deactivate", deactivate_card_path(current_account.slug, @card), class: "btn" %>
      <%= button_to "Done", done_card_path(current_account.slug, @card), class: "btn" %>
    <% elsif !@card.done? %>
      <%= button_to "Activate", activate_card_path(current_account.slug, @card), class: "btn btn-primary" %>
    <% end %>
    <%= link_to "Edit", edit_card_path(current_account.slug, @card), class: "btn" %>
    <%= link_to "Events", card_events_path(current_account.slug, @card), class: "btn" %>
    <%= button_to "Delete", card_path(current_account.slug, @card), method: :delete, class: "btn btn-danger" %>
  </div>
</div>

<% if @focus_session_count > 0 %>
  <div class="activity-summary">
    <h2>Activity</h2>
    <p class="stat"><strong><%= distance_of_time_in_words(@total_focus_seconds) %></strong> focused across <strong><%= @focus_session_count %></strong> <%= "session".pluralize(@focus_session_count) %></p>
  </div>
<% end %>

<% if @backlinks.any? %>
  <div class="backlinks">
    <h2>Mentioned By</h2>
    <% @backlinks.each do |mention| %>
      <div class="backlink">
        <%= link_to mention.comment.card.title, card_path(current_account.slug, mention.comment.card) %>
        <span class="backlink-meta">&middot; <%= mention.comment.creator.name %>, <%= mention.comment.created_at.strftime("%b %d") %></span>
      </div>
    <% end %>
  </div>
<% end %>

<div class="comments">
  <h2>Comments</h2>

  <% @card.comments.order(created_at: :desc).includes(:creator).each do |comment| %>
    <div class="comment">
      <div class="comment-meta"><%= comment.creator.name %> &middot; <%= comment.created_at.strftime("%b %d, %H:%M") %></div>
      <div class="comment-body"><%= linkify_mentions(comment.body, current_account) %></div>
    </div>
  <% end %>

  <%= form_with scope: :comment, url: card_comments_path(current_account.slug, @card), method: :post do |f| %>
    <div class="form-group">
      <%= f.rich_text_area :body, placeholder: "Add a comment..." %>
    </div>
    <%= f.submit "Comment", class: "btn btn-primary" %>
  <% end %>
</div>

<div class="section-gap">
  <h2>Tags</h2>
  <%= form_with scope: :tagging, url: card_taggings_path(current_account.slug, @card), method: :post do |f| %>
    <div class="form-group form-inline">
      <%= f.text_field :tag_name, placeholder: "Add a tag...", style: "flex: 1;", list: "tag-suggestions", autocomplete: "off" %>
      <datalist id="tag-suggestions">
        <% @suggested_tags.each do |name| %>
          <option value="<%= name %>">
        <% end %>
      </datalist>
      <%= f.submit "Tag", class: "btn" %>
    </div>
  <% end %>
</div>
