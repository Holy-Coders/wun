<h1>Edit card</h1>

<%= form_with model: @card, url: card_path(current_account.slug, @card) do |f| %>
  <div class="form-group">
    <%= f.label :title %>
    <%= f.text_field :title, autofocus: true, required: true %>
  </div>

  <div class="form-group">
    <%= f.label :body %>
    <%= f.rich_text_area :body %>
  </div>

  <%= f.submit "Save", class: "btn btn-primary" %>
  <%= link_to "Cancel", card_path(current_account.slug, @card), class: "btn" %>
<% end %>
