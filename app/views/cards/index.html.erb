<% if @outside_working_hours && !@after_hours_active %>
  <div class="after-hours-banner">
    <p>After hours. Wun isn't tracking unless you say so.</p>
    <%= button_to "I'm working late", working_late_path(current_account.slug), class: "btn btn-primary" %>
  </div>
<% elsif @after_hours_active %>
  <div class="after-hours-banner after-hours-active">
    <p>Working late. Focus tracking is on.</p>
  </div>
<% end %>

<% if @active_card %>
  <div data-controller="idle"
       data-idle-threshold-value="900"
       data-idle-adjust-url-value="<%= idle_deactivate_card_path(current_account.slug, @active_card) %>">
  <h2>Active</h2>
  <div class="active-card">
    <div class="card-title">
      <%= link_to @active_card.title, card_path(current_account.slug, @active_card) %>
    </div>
    <% if @active_card.body.present? %>
      <div class="card-body"><%= truncate(@active_card.body.to_plain_text, length: 120) %></div>
    <% end %>
    <div class="tags">
      <% @active_card.tags.reject(&:system?).each do |tag| %>
        <span class="tag"><%= tag.name %></span>
      <% end %>
    </div>
    <div class="actions">
      <%= button_to "Deactivate", deactivate_card_path(current_account.slug, @active_card), class: "btn" %>
      <%= button_to "Done", done_card_path(current_account.slug, @active_card), class: "btn" %>
    </div>
  </div>
  </div>
<% else %>
  <div class="pause-state">
    <% case @pause_reason %>
    <% when :working_hours %>
      <p>After hours. Wun isn't tracking unless you say so.</p>
    <% when :idle %>
      <p>Stepped away. Pick up where you left off, or choose something else.</p>
    <% when :manual %>
      <p>Nothing is active. Pick one thing to focus on.</p>
    <% else %>
      <p>Nothing is active. Pick one thing to focus on.</p>
    <% end %>

    <% if @last_active_card %>
      <div class="resume-prompt">
        <span>Last active: <strong><%= @last_active_card.title %></strong></span>
        <%= button_to "Resume", activate_card_path(current_account.slug, @last_active_card), class: "btn btn-primary" %>
      </div>
    <% else %>
      <p class="muted">Choose one card from the deck.</p>
    <% end %>
  </div>
<% end %>

<h2>On Deck</h2>

<% if @on_deck_cards.any? %>
  <ul class="deck-list">
    <% @on_deck_cards.each do |card| %>
      <li class="deck-item">
        <div>
          <div class="card-title">
            <%= link_to card.title, card_path(current_account.slug, card) %>
          </div>
          <div class="tags">
            <% visible_tag = if card.blocked?
                               "Blocked"
                             else
                               card.tags.reject { |t| t.system? || StructuredTag.new(t.name).card_ref? }.first&.name
                             end %>
            <% if visible_tag %>
              <span class="tag"><%= visible_tag %></span>
            <% end %>
          </div>
        </div>
        <div class="deck-actions">
          <%= button_to "Activate", activate_card_path(current_account.slug, card), class: "btn btn-primary" %>
          <div class="move-buttons">
            <%= button_to "\u25B2", move_card_path(current_account.slug, card, direction: "up"), class: "btn btn-move" %>
            <%= button_to "\u25BC", move_card_path(current_account.slug, card, direction: "down"), class: "btn btn-move" %>
          </div>
        </div>
      </li>
    <% end %>
  </ul>
<% else %>
  <div class="empty">Nothing on deck. Create a card when you're ready to focus.</div>
<% end %>

<div class="section-gap">
  <%= link_to "New card", new_card_path(current_account.slug), class: "btn btn-primary" %>
</div>
